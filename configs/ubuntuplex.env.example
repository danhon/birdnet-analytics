# birdnet-analytics (UBUNTUPLEX) example config
# Copy to: configs/ubuntuplex.env

# Directory that contains BirdNET-GO's sqlite DB file(s)
BIRDNET_DB_DIR=/home/danhon/birdnet-go-app/data

# If you know the exact sqlite filename, set it (preferred)
# BIRDNET_DB_PATH=/home/danhon/birdnet-go-app/data/birdnet.db

# Bind/port for web server
BIRDNET_ANALYTICS_HOST=0.0.0.0
BIRDNET_ANALYTICS_PORT=8787

# Optional: base path if you want to reverse-proxy under /birdnet/
# BIRDNET_ANALYTICS_ROOT_PATH=/birdnet
